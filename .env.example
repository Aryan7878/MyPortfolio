# GitHub Personal Access Token
# Required for: contribution calendar (GraphQL), pinned repositories (GraphQL)
# Optional but recommended for: higher REST API rate limit (5000/hr vs 60/hr)
#
# How to generate:
#   1. Go to https://github.com/settings/tokens/new
#   2. Select scopes: read:user  and  public_repo
#   3. Copy the generated token below
#   4. Rename this file to  .env  (no .example)
#
VITE_GITHUB_TOKEN=ghp_your_token_here
